import { VerticalBox, HorizontalBox, Button } from "std-widgets.slint";
import { ThemeSwitcher } from "../components/ThemeSwitcher.slint";
import { Theme } from "../theme.slint";
import { ConversationList } from "../components/ConversationList.slint";
import { ConversationLayout } from "Conversation.slint";
import { ImageButton } from "../components/ImageButton.slint";
import { Auth } from "Log.slint";
import { I18n } from "../models/I18n.slint";

export component MainLayout inherits HorizontalBox {
    Rectangle {
        height: 100%;
        width: 20%;
        min-width: 250px;
        background: Theme.background-light;
        VerticalBox {
            HorizontalLayout {
                alignment: space-between;
                spacing: 4px;

                ThemeSwitcher { }

                // Language toggle FR/EN
                Rectangle {
                    width: 32px;
                    height: 32px;
                    border-radius: 6px;
                    background: lang-touch.has-hover ? Theme.surface-hover : transparent;

                    lang-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            I18n.is-french = !I18n.is-french;
                        }
                    }

                    Text {
                        text: I18n.is-french ? "FR" : "EN";
                        font-size: 12px;
                        font-weight: 700;
                        color: Theme.text-main;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                }

                // Logout button
                Rectangle {
                    width: 32px;
                    height: 32px;
                    border-radius: 6px;
                    background: logout-touch.has-hover ? #ff444430 : transparent;

                    logout-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            Auth.logout();
                        }
                    }

                    Text {
                        text: "⏻";
                        font-size: 18px;
                        color: logout-touch.has-hover ? #ff4444 : Theme.text-muted;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            ConversationList { }
        }
    }

    Rectangle {
        ConversationLayout { }
    }
}

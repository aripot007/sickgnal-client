import {
    VerticalBox,
    LineEdit,
    ScrollView,
    HorizontalBox,
} from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { MessageBubble } from "../components/MessageBubble.slint";
import { Chat } from "../models/Chat.slint";
import { Conversation } from "../models/Conversation.slint";
import { Button } from "../components/Button.slint";
import { ConversationSettings } from "ConversationSettings.slint";
import { I18n } from "../models/I18n.slint";

component ChatInput inherits Rectangle {
    in-out property <string> text <=> input.text;
    in property <string> placeholder-text: I18n.write-message;
    in property <bool> enabled: true;

    callback send();
    callback edited();

    // Height adapts to the text content, clamped between min and max
    private property <length> content-height: input.preferred-height + 16px;
    private property <length> max-input-height: 150px;
    height: clamp(root.content-height, 40px, root.max-input-height);

    background: Theme.surface;
    border-radius: 8px;
    border-width: 1px;
    border-color: input.has-focus ? Theme.primary : Theme.border;

    scroll := ScrollView {
        x: 10px;
        y: 0;
        width: parent.width - 20px;
        height: parent.height;
        viewport-height: max(input.preferred-height + 16px, parent.height);

        VerticalLayout {
            alignment: center;
            padding-top: 8px;
            padding-bottom: 8px;

            input := TextInput {
                width: scroll.width - 12px;
                single-line: false;
                wrap: word-wrap;
                font-size: 14px;
                color: root.enabled ? Theme.text-main : Theme.text-muted;
                enabled: root.enabled;

                edited => {
                    root.edited();
                    // Auto-scroll to bottom when content overflows
                    if (input.preferred-height + 16px > scroll.height) {
                        scroll.viewport-y = -(input.preferred-height + 16px - scroll.height);
                    }
                }

                key-pressed(event) => {
                    // Enter without Shift => send
                    if (event.text == "\n" && !event.modifiers.shift) {
                        root.send();
                        return accept;
                    }
                    return reject;
                }
            }
        }
    }

    // Placeholder text
    if (input.text == ""): Text {
        x: 10px;
        y: 0;
        height: parent.height;
        text: root.placeholder-text;
        font-size: 14px;
        color: Theme.text-muted;
        vertical-alignment: center;
    }
}

export component ConversationLayout inherits VerticalBox {
    private property <bool> show-typing: false;
    
    private property <bool> raw-typing: Chat.get-current-conversation().is-typing;
    private property <int> active-id: Chat.active_chat_id;

    padding: 0;
    spacing: 0;

    typing-timer := Timer {
        interval: 5s;
        running: false;
        triggered => {
            root.show-typing = false;
            self.running = false;
        }
    }

    // Reset on conversation switch
    changed active-id => {
        root.show-typing = false;
        typing-timer.running = false;
    }

    // React to typing indicator changes
    changed raw-typing => {
        if (root.raw-typing) {
            root.show-typing = true;
            typing-timer.running = false;
            typing-timer.running = true;
        }
    }

    Rectangle {
        height: 50px;
        background: Theme.background-light;
        border-color: Theme.background-dark;

        HorizontalLayout {
            padding-left: 15px;
            padding-right: 10px;

            Text {
                text: Chat.current.name;
                font-size: 18px;
                font-weight: 600;
                color: Theme.text-main;
                horizontal-alignment: left;
                vertical-alignment: center;
            }

            Rectangle { }

            if Chat.has-active-conversation(): Rectangle {
                width: 32px;
                height: 32px;
                border-radius: 6px;
                background: info-touch.has-hover ? Theme.surface-hover : transparent;

                info-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        Chat.open_conversation_settings();
                    }
                }

                Text {
                    text: "ⓘ";
                    font-size: 18px;
                    color: Theme.text-muted;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }

    // Conversation settings view (replaces messages when open)
    if Chat.show_conversation_settings: ConversationSettings { }

    // Messages view (hidden when settings is open)
    if !Chat.show_conversation_settings: ScrollView {
        VerticalBox {
            padding: 15px;
            alignment: start;
            spacing: 10px;
            if Chat.has-active-conversation() == false: Rectangle {
                VerticalBox {
                    alignment: center;
                    Text {
                        text: I18n.select-conversation;
                        font-size: 16px;
                        color: Theme.text-muted;
                        horizontal-alignment: center;
                    }
                }
            }
            for msg in Chat.get-current-conversation().messages: MessageBubble {
                id: msg.id;
                text: msg.text;
                time: msg.time;
                status: msg.status;
                is-me: msg.is_me;
                reply_to_text: msg.reply_to_text;
            }
        }
    }

    if root.show-typing && !Chat.show_conversation_settings: HorizontalBox {
        alignment: start;
        spacing: 6px;
        padding: 2px;
        Text {
            text: Chat.get-current-conversation().typing-user-name + I18n.is-typing-suffix;
            font-size: 13px;
            color: Theme.text-muted;
            vertical-alignment: center;
        }
    }

    // Reply bar (shown above input when replying)
    if Chat.is_replying && !Chat.show_conversation_settings: Rectangle {
        height: 40px;
        background: Theme.surface;
        border-color: Theme.background-dark;

        HorizontalLayout {
            padding: 8px;
            padding-left: 15px;
            spacing: 8px;

            Rectangle {
                width: 3px;
                background: Theme.primary;
                border-radius: 1px;
            }

            VerticalLayout {
                alignment: center;
                Text {
                    text: I18n.replying-to;
                    font-size: 11px;
                    font-weight: 600;
                    color: Theme.primary;
                }
                Text {
                    text: Chat.reply_to_preview;
                    font-size: 12px;
                    color: Theme.text-muted;
                    overflow: elide;
                }
            }

            Rectangle { }

            Rectangle {
                width: 28px;
                height: 28px;
                border-radius: 14px;
                background: cancel-reply-touch.has-hover ? Theme.surface-hover : transparent;

                cancel-reply-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        Chat.cancel_reply();
                    }
                }

                Text {
                    text: "✕";
                    font-size: 14px;
                    color: Theme.text-muted;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }

    if !Chat.show_conversation_settings: Rectangle {
        background: Theme.background-light;
        border-color: Theme.background-dark;
        HorizontalLayout {
            padding: 10px;
            spacing: 10px;

            input := ChatInput {
                horizontal-stretch: 1;
                placeholder-text: Chat.is_editing ? I18n.edit-message-placeholder : Chat.is_replying ? I18n.type-reply : I18n.write-message;
                text: Chat.editing_text;
                enabled: Chat.active_chat_id >= 0;
                edited => {
                    Chat.typing();
                }
                send => {
                    if (input.text != "") {
                        if (Chat.is_editing) {
                            Chat.edit_message(Chat.editing_message_id, input.text);
                            input.text = "";
                        } else {
                            Chat.send_message(input.text);
                            input.text = "";
                        }
                    }
                }
            }

            VerticalLayout {
                alignment: end;
                spacing: 8px;

                if Chat.is_editing: Button {
                    text: I18n.cancel;
                    btn_width: 60px;
                    clicked => {
                        Chat.cancel_edit();
                        input.text = "";
                    }
                }

                Button {
                    text: Chat.is_editing ? I18n.save : I18n.send;
                    enabled: Chat.active_chat_id >= 0 && input.text != "";
                    btn_width: 70px;
                    clicked => {
                        if (Chat.is_editing) {
                            Chat.edit_message(Chat.editing_message_id, input.text);
                            input.text = "";
                        } else {
                            Chat.send_message(input.text);
                            input.text = "";
                        }
                    }
                }
            }
        }
    }
}

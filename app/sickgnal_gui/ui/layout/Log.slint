import { VerticalBox, Button } from "std-widgets.slint";
import { I18n } from "../models/I18n.slint";
import { Theme } from "../theme.slint";
import { ChatInput } from "../components/ChatInput.slint";

export global Auth {
    in-out property <string> username: "";
    in-out property <bool> is-logged-in: false;
    callback sign-in(string);
    in-out property <bool> incorrect-password: false;
    callback sign-up(string, string, string);
    in-out property <bool> already-existing-username: false;
    in-out property <bool> different-password: false;
    in-out property <string> tls-warning: "";
    callback logout();
    // Back to profile select (only relevant when profiles exist)
    in-out property <bool> has-existing-profiles: false;
    callback back-to-profiles();
}

component SignIn inherits VerticalBox {
    Text {
        font-size: 16px;
        text: I18n.user-found-prefix + Auth.username + I18n.user-found-suffix;
        color: green;
    }

    Timer {
        interval: 2s;
        running: Auth.incorrect-password; 
        triggered() => {
            Auth.incorrect-password = false; 
        }
    }

    passwd := ChatInput {
        placeholder-text: I18n.password-placeholder;
        enabled: !Auth.incorrect-password;
        input-type: password;
        height: 30px;
        send => { Auth.sign-in(self.text) }
    }

    if (Auth.incorrect-password) : Text {
        font-size: 16px;
        text: I18n.incorrect-password;
        color: red;
    }

    Button {
        text: I18n.sign-in;
        primary: true;
        enabled: !Auth.incorrect-password;
        height: 30px;
        clicked => {
            Auth.sign-in(passwd.text)
        }
    }
}

component SignUp inherits VerticalBox {
    spacing: 12px;

    // --- LOGIQUE DES TIMERS ---
    // Timer pour "Utilisateur déjà existant"
    Timer {
        interval: 2s;
        running: Auth.already-existing-username;
        triggered() => { Auth.already-existing-username = false; }
    }

    // Timer pour "Mots de passe différents"
    Timer {
        interval: 2s;
        running: Auth.different-password;
        triggered() => { Auth.different-password = false; }
    }

    // --- INTERFACE ---
    Text {
        font-size: 16px;
        text: I18n.no-account-found;
        color: orange;
        horizontal-alignment: center;
    }

    user := ChatInput {
        placeholder-text: I18n.username-placeholder;
        enabled: !Auth.already-existing-username && !Auth.different-password;
        height: 35px;
    }

    passwd := ChatInput {
        placeholder-text: I18n.password-placeholder;
        input-type: password;
        enabled: !Auth.already-existing-username && !Auth.different-password;
        height: 35px;
    }

    confirm-password := ChatInput {
        placeholder-text: I18n.confirm-password-placeholder;
        input-type: password;
        enabled: !Auth.already-existing-username && !Auth.different-password;
        height: 35px;
        send => { Auth.sign-up(user.text, passwd.text, self.text) }
    }

    // --- AFFICHAGE DES ERREURS ---
    if (Auth.already-existing-username) : Text {
        text: I18n.username-exists;
        color: red;
        font-size: 14px;
        horizontal-alignment: center;
    }

    if (Auth.different-password) : Text {
        text: I18n.passwords-dont-match;
        color: red;
        font-size: 14px;
        horizontal-alignment: center;
    }

    Button {
        text: I18n.create-account;
        primary: true;
        height: 35px;
        enabled: !Auth.already-existing-username && !Auth.different-password;
        clicked => {
            Auth.sign-up(user.text, passwd.text, confirm-password.text)
        }
    }
}

export component LogLayout inherits VerticalBox {
    height: 400px;
    width: 400px;
    alignment: center;

    if (Auth.tls-warning != ""): Text {
        text: Auth.tls-warning;
        font-size: 13px;
        font-weight: 600;
        color: #cc8800;
        horizontal-alignment: center;
    }

    if (Auth.username != ""): SignIn { }
    if (Auth.username == ""): SignUp { }

    // Back button — only visible on signup when profiles already exist
    if (Auth.username == "" && Auth.has-existing-profiles): Rectangle {
        height: 40px;
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 80px;
                height: 32px;
                border-radius: 6px;
                background: back-touch.has-hover ? Theme.surface-hover : transparent;

                back-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        Auth.back-to-profiles();
                    }
                }

                Text {
                    text: "← " + I18n.back;
                    font-size: 14px;
                    color: Theme.text-muted;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
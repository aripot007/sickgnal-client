import { ScrollView, VerticalBox, HorizontalBox, Spinner } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { ConversationItem } from "../components/ConversationItem.slint";
import { Chat } from "../models/Chat.slint";
import { ImageButton } from "ImageButton.slint";
import { I18n } from "../models/I18n.slint";
import { NewConvOrGroupDialog } from "../components/NewConvOrGroupDialog.slint";

component ContextMenuItem inherits Rectangle {
    in property <string> label;
    in property <string> icon;
    in property <bool> is-destructive: false;

    callback clicked();

    height: 32px;
    border-radius: 6px;
    background: item-touch.has-hover ? Theme.surface-hover : transparent;

    item-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 8px;

        Text {
            text: root.icon;
            font-size: 13px;
            color: root.is-destructive ? #cc3333 : Theme.text-main;
            vertical-alignment: center;
        }
        Text {
            text: root.label;
            font-size: 13px;
            color: root.is-destructive ? #cc3333 : Theme.text-main;
            vertical-alignment: center;
        }
    }
}

export component ConversationList inherits Rectangle {
    background: Theme.background-light;
    VerticalBox {
        padding: 0;
        padding-top: 8px;
        HorizontalBox {
            padding: 0;
            Text {
                text: I18n.conversations;
                font-size: 18px;
                font-weight: 700;
                vertical-alignment: center;
                color: Theme.text-main;
                horizontal-alignment: left;
                overflow: elide;
            }

            ImageButton {
                image: @image-url("../assets/add.png");
                clicked => {
                    Chat.show_new_conv_or_group_dialog = !Chat.show_new_conv_or_group_dialog;
                }
            }
        }

        if Chat.is_loading: VerticalBox {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Spinner {
                    indeterminate: true;
                    width: 32px;
                    height: 32px;
                }
            }
            Text {
                text: I18n.loading-conversations;
                font-size: 13px;
                color: Theme.text-muted;
                horizontal-alignment: center;
            }
        }

        if !Chat.is_loading && Chat.chats.length == 0: VerticalBox {
            alignment: center;
            spacing: 8px;
            padding-top: 40px;

            Text {
                text: I18n.no-conversations;
                font-size: 15px;
                font-weight: 500;
                color: Theme.text-muted;
                horizontal-alignment: center;
            }
            Text {
                text: I18n.no-conversations-hint;
                font-size: 12px;
                color: Theme.text-muted;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }

        if !Chat.is_loading && Chat.chats.length > 0: ScrollView {
            viewport-height: self.visible-height;
            VerticalBox {
                alignment: start;
                for conv[index] in Chat.chats: ConversationItem {
                    conversation_id: conv.id;
                    name: conv.name;
                    last_message: conv.last_message;
                    last_message_time: conv.last_message_time;
                    unread_count: conv.unread_count;
                    is_active: index == Chat.active_chat_id;
                    clicked => {
                        Chat.show_context_menu = false;
                        Chat.switch_conversation(index);
                    }
                    delete_clicked => {
                        Chat.delete_conversation(index);
                    }
                    right_clicked(x, y) => {
                        Chat.context_menu_index = index;
                        Chat.context_menu_x = x;
                        Chat.context_menu_y = y;
                        Chat.show_context_menu = true;
                    }
                }
            }
        }
    }

    // Context menu overlay
    if Chat.show_context_menu: Rectangle {
        width: 100%;
        height: 100%;

        // Click-away to dismiss
        TouchArea {
            clicked => {
                Chat.show_context_menu = false;
            }
        }

        Rectangle {
            x: Chat.context_menu_x;
            y: Chat.context_menu_y;
            width: 160px;
            height: 108px;
            background: Theme.surface;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 8px;
            drop-shadow-color: #00000030;

            // Block click-through
            TouchArea {}

            VerticalLayout {
                padding: 4px;
                spacing: 2px;

                ContextMenuItem {
                    icon: "✎";
                    label: I18n.rename;
                    clicked => {
                        Chat.show_context_menu = false;
                        Chat.switch_conversation(Chat.context_menu_index);
                        Chat.open_conversation_settings();
                    }
                }

                ContextMenuItem {
                    icon: "+";
                    label: I18n.add-member;
                    clicked => {
                        Chat.show_context_menu = false;
                        Chat.switch_conversation(Chat.context_menu_index);
                        Chat.add_member();
                    }
                }

                ContextMenuItem {
                    icon: "✕";
                    label: I18n.delete;
                    is-destructive: true;
                    clicked => {
                        Chat.show_context_menu = false;
                        Chat.delete_conversation(Chat.context_menu_index);
                    }
                }
            }
        }
    }
}

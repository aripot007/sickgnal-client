import { Theme } from "../theme.slint";
import { StatusIcon } from "StatusIcon.slint";
import { Chat } from "../models/Chat.slint";
import { I18n } from "../models/I18n.slint";

component BubbleBase inherits HorizontalLayout {
    in property <string> text;
    in property <string> time;
    in property <string> status;
    in property <string> reply_to_text;
    in property <LayoutAlignment> bubble-alignment;
    in property <length> pad-left;
    in property <length> pad-right;
    in property <color> bg-color;
    in property <color> text-color;
    in property <length> radius-right;
    in property <length> radius-left;

    callback menu-requested(/* abs-x */ length, /* abs-y */ length);

    alignment: root.bubble-alignment;
    padding-left: root.pad-left;
    padding-right: root.pad-right;

    Rectangle {
        background: root.bg-color;
        border-radius: Theme.border-radius;
        border-bottom-right-radius: root.radius-right;
        border-bottom-left-radius: root.radius-left;

        // Hover + right-click area covering the bubble background
        // Rendered first (lowest Z), so the menu button on top can receive clicks
        bubble-hover := TouchArea {
            mouse-cursor: default;
            pointer-event(event) => {
                if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                    root.menu-requested(
                        self.absolute-position.x + self.mouse-x,
                        self.absolute-position.y + self.mouse-y
                    );
                }
            }
        }

        VerticalLayout {
            padding: 10px;
            spacing: 4px;

            // Quoted reply block
            if root.reply_to_text != "": Rectangle {
                background: Theme.background-dark;
                border-radius: 6px;
                border-color: Theme.primary;

                HorizontalLayout {
                    padding: 6px;
                    padding-left: 8px;
                    spacing: 6px;

                    Rectangle {
                        width: 3px;
                        background: Theme.primary;
                        border-radius: 1px;
                    }

                    Text {
                        text: root.reply_to_text;
                        color: root.text-color;
                        opacity: 0.7;
                        font-size: 12px;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                }
            }

            Text {
                text: root.text;
                color: root.text-color;
                font-size: 14px;
                wrap: word-wrap;
            }

            HorizontalLayout {
                alignment: end;
                spacing: 8px;
                Text {
                    vertical-alignment: center;
                    text: root.time;
                    font-size: 10px;
                    color: root.text-color;
                    opacity: 0.75;
                }

                if (root.status == "sent" || root.status == "sending" || root.status == "read"): StatusIcon {
                    status: root.status;
                    color: root.text-color;
                }
            }
        }

        // Menu button — top-right, rendered LAST (highest Z) so it gets clicks
        Rectangle {
            x: parent.width - self.width - 4px;
            y: 4px;
            width: 26px;
            height: 26px;
            border-radius: 13px;
            background: menu-btn-touch.has-hover ? #00000035 :
                         bubble-hover.has-hover ? #00000018 : transparent;
            opacity: bubble-hover.has-hover || menu-btn-touch.has-hover ? 1.0 : 0.0;

            menu-btn-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.menu-requested(
                        self.absolute-position.x + 13px,
                        self.absolute-position.y + 26px
                    );
                }
            }

            Text {
                text: "▾";
                font-size: 14px;
                color: root.text-color;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

component LMessageBubble inherits BubbleBase {
    bubble-alignment: start;
    pad-left: Theme.message-bubble-inner-pad;
    pad-right: Theme.message-bubble-inner-pad * 10;
    bg-color: Theme.surface;
    text-color: Theme.on-surface;
    radius-left: 0px;
    radius-right: Theme.border-radius;
}

component RMessageBubble inherits BubbleBase {
    bubble-alignment: end;
    pad-left: Theme.message-bubble-inner-pad * 10;
    pad-right: Theme.message-bubble-inner-pad;
    bg-color: Theme.primary;
    text-color: Theme.on-primary;
    radius-left: Theme.border-radius;
    radius-right: 0px;
}

export component MessageBubble inherits Rectangle {
    in property <string> id;
    in property <string> text;
    in property <string> time;
    in property <string> status;
    in property <bool> is-me;
    in property <string> reply_to_text;

    function open-menu(abs-x: length, abs-y: length) {
        Chat.message_menu_id = root.id;
        Chat.message_menu_text = root.text;
        Chat.message_menu_is_me = root.is-me;
        Chat.message_menu_x = abs-x;
        Chat.message_menu_y = abs-y;
        Chat.show_message_menu = true;
    }

    HorizontalLayout {
        if (root.is-me): RMessageBubble {
            text: root.text;
            time: root.time;
            status: root.status;
            reply_to_text: root.reply_to_text;
            menu-requested(x, y) => {
                root.open-menu(x, y);
            }
        }
        if (!root.is-me): LMessageBubble {
            text: root.text;
            time: root.time;
            status: root.status;
            reply_to_text: root.reply_to_text;
            menu-requested(x, y) => {
                root.open-menu(x, y);
            }
        }
    }
}

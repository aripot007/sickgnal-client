import { LineEdit } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { Chat } from "../models/Chat.slint";
import { Button } from "Button.slint";

export component NewConversationDialog inherits Rectangle {
    // Full-screen semi-transparent backdrop
    width: 100%;
    height: 100%;
    background: #00000060;

    // Block clicks from reaching content behind
    TouchArea {}

    // Centered card
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 400px;
        height: 220px;
        background: Theme.surface;
        border-radius: 12px;
        drop-shadow-blur: 20px;
        drop-shadow-color: #00000040;

        VerticalLayout {
            padding: 24px;
            spacing: 16px;

            Text {
                text: "New Conversation";
                font-size: Theme.font-size-title;
                font-weight: 700;
                color: Theme.text-main;
                horizontal-alignment: center;
            }

            username-input := LineEdit {
                placeholder-text: "Enter username...";
                font-size: 14px;
            }

            if Chat.new_conversation_error != "": Text {
                text: Chat.new_conversation_error;
                color: #cc3333;
                font-size: 12px;
                horizontal-alignment: center;
            }

            HorizontalLayout {
                alignment: end;
                spacing: 10px;

                Button {
                    text: "Cancel";
                    btn_width: 80px;
                    clicked => {
                        debug("call to cancel_new_conversation");
                        Chat.cancel_new_conversation();
                        debug("show_new_conversation_dialog =", Chat.show_new_conversation_dialog);
                    }
                }

                Button {
                    text: "Create";
                    btn_width: 80px;
                    enabled: username-input.text != "";
                    clicked => {
                        debug("call to confirm_new_conversation");
                        Chat.confirm_new_conversation(username-input.text);
                    }
                }
            }
        }
    }
}

import { Theme } from "../theme.slint";
import { Chat } from "../models/Chat.slint";
import { I18n } from "../models/I18n.slint";

component MenuItem inherits Rectangle {
    in property <string> label;
    in property <string> icon;
    in property <bool> is-destructive: false;

    callback clicked();

    height: 34px;
    border-radius: 6px;
    background: item-touch.has-hover ? Theme.surface-hover : transparent;

    item-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;

        Text {
            text: root.icon;
            font-size: 13px;
            color: root.is-destructive ? #cc3333 : Theme.text-main;
            vertical-alignment: center;
        }
        Text {
            text: root.label;
            font-size: 13px;
            color: root.is-destructive ? #cc3333 : Theme.text-main;
            vertical-alignment: center;
        }
    }
}

export component MessageMenu inherits Rectangle {
    width: 100%;
    height: 100%;
    background: transparent;

    // Click anywhere outside to dismiss (both left and right click)
    dismiss-area := TouchArea {
        pointer-event(event) => {
            if (event.kind == PointerEventKind.up) {
                Chat.show_message_menu = false;
            }
        }
    }

    Rectangle {
        // Position: for our messages (is_me) menu opens to the LEFT of click point
        // For others' messages, menu opens to the RIGHT of click point
        x: Chat.message_menu_is_me ? Chat.message_menu_x - 150px : Chat.message_menu_x;
        y: Chat.message_menu_y;
        width: 150px;
        height: Chat.message_menu_is_me ? 114px : 42px;
        background: Theme.surface;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-blur: 10px;
        drop-shadow-color: #00000040;

        // Block click-through on the menu itself
        TouchArea {}

        VerticalLayout {
            padding: 4px;
            spacing: 2px;

            MenuItem {
                icon: "↩";
                label: I18n.reply;
                clicked => {
                    Chat.start_reply(Chat.message_menu_id, Chat.message_menu_text);
                    Chat.show_message_menu = false;
                }
            }

            if Chat.message_menu_is_me: MenuItem {
                icon: "✎";
                label: I18n.edit;
                clicked => {
                    Chat.start_edit(Chat.message_menu_id, Chat.message_menu_text);
                    Chat.show_message_menu = false;
                }
            }

            if Chat.message_menu_is_me: MenuItem {
                icon: "✕";
                label: I18n.delete;
                is-destructive: true;
                clicked => {
                    Chat.delete_message(Chat.message_menu_id);
                    Chat.show_message_menu = false;
                }
            }
        }
    }
}

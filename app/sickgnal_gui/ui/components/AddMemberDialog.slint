import { Theme } from "../theme.slint";
import { Chat } from "../models/Chat.slint";
import { Button } from "Button.slint";
import { I18n } from "../models/I18n.slint";
import { ChatInput } from "ChatInput.slint";

export component AddMemberDialog inherits Rectangle {
    // Full-screen semi-transparent backdrop
    background: #00000060;

    // Block clicks from reaching content behind
    TouchArea {}

    // Centered card
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 400px;
        height: 220px;
        background: Theme.surface;
        border-radius: 12px;
        drop-shadow-blur: 20px;
        drop-shadow-color: #00000040;

        VerticalLayout {
            padding: 24px;
            spacing: 16px;

            Text {
                text: I18n.add-member-title;
                font-size: Theme.font-size-title;
                font-weight: 700;
                color: Theme.text-main;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            username-input := ChatInput {
                placeholder-text: I18n.enter-username;
            }

            if Chat.add_member_error != "": Text {
                text: Chat.add_member_error;
                color: #cc3333;
                font-size: 12px;
                horizontal-alignment: center;
            }

            HorizontalLayout {
                alignment: end;
                spacing: 15px;

                Button {
                    text: I18n.cancel;
                    btn_width: 80px;
                    clicked => {
                        Chat.cancel_add_member();
                    }
                }

                Button {
                    text: I18n.add;
                    btn_width: 80px;
                    enabled: username-input.text != "";
                    clicked => {
                        Chat.confirm_add_member(username-input.text);
                    }
                }
            }
        }
    }
}

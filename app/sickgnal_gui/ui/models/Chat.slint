import { Conversation } from "Conversation.slint";
import { PeerData } from "Peer.slint";

export global Chat {
    in-out property <[Conversation]> chats: [];
    in-out property <int> active_chat_id: -1;
    in-out property <bool> is_loading: true;

    // Auto-scroll
    in-out property <int> new_messages_count: 0;
    in-out property <bool> should_scroll_to_bottom: false;

    // Editing state
    in-out property <bool> is_editing: false;
    in-out property <string> editing_message_id: "";
    in-out property <string> editing_text: "";

    out property <Conversation> current: chats[active_chat_id];
    public pure function get-current-conversation() -> Conversation {
        if (root.active_chat_id >= 0 && root.active_chat_id < root.chats.length) {
            return root.chats[root.active_chat_id];
        }
        return { id: "", name: "", last_message: "", last_message_time: "", unread_count: 0, messages: [] };
    }
    public pure function has-active-conversation() -> bool {
        return root.active_chat_id >= 0 && root.active_chat_id < root.chats.length;
    }
    callback switch_conversation(int);
    callback delete_conversation(int);
    callback send_message(string);
    callback create_new_conversation();
    callback confirm_new_conversation();
    callback clear_new_conversation_users();
    callback cancel_new_conversation();
    callback add_user_to_new_conversation(/* username */ string);
    callback remove_user_from_new_conversation(/* index */ int);

    // Context menu on conversation item
    in-out property <bool> show_context_menu: false;
    in-out property <int> context_menu_index: -1;
    in-out property <length> context_menu_x: 0;
    in-out property <length> context_menu_y: 0;

    // New conversation dialog state
    in-out property <bool> show_new_conversation_dialog: false;
    in-out property <bool> show_new_conv_or_group_dialog: false;
    in-out property <bool> new_conversation_is_group: false;
    in-out property <string> new_conversation_error: "";
    in-out property <[string]> new_conversation_users: [];

    // New conversation "+" sub-menu
    in-out property <bool> show_new_conv_menu: false;

    callback edit_message(/* msg_id */ string, /* new_text */ string);
    callback delete_message(/* msg_id */ string);
    callback start_edit(/* msg_id */ string, /* current_text */ string);
    callback cancel_edit();

    // Conversation settings
    in-out property <bool> show_conversation_settings: false;
    in-out property <[PeerData]> current_peers;
    callback open_conversation_settings();
    callback close_conversation_settings();
    callback rename_conversation(/* new_name */ string);
    callback add_member();

    // Typing indicator
    callback typing();

    // Reply state
    in-out property <bool> is_replying: false;
    in-out property <string> reply_to_message_id: "";
    in-out property <string> reply_to_preview: "";
    callback start_reply(/* msg_id */ string, /* preview_text */ string);
    callback cancel_reply();

    // Message context menu (global overlay)
    in-out property <bool> show_message_menu: false;
    in-out property <string> message_menu_id: "";
    in-out property <string> message_menu_text: "";
    in-out property <bool> message_menu_is_me: false;
    in-out property <length> message_menu_x: 0;
    in-out property <length> message_menu_y: 0;

    // Add member dialog state
    in-out property <bool> show_add_member_dialog: false;
    in-out property <string> add_member_error: "";
    callback confirm_add_member(/* username */ string);
    callback cancel_add_member();
}

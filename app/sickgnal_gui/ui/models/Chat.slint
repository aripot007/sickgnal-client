import { Conversation } from "Conversation.slint";
import { PeerData } from "Peer.slint";

export global Chat {
    in-out property <[Conversation]> chats: [];
    in-out property <int> active_chat_id: -1;

    // Editing state
    in-out property <bool> is_editing: false;
    in-out property <string> editing_message_id: "";
    in-out property <string> editing_text: "";

    out property <Conversation> current: chats[active_chat_id];
    public pure function get-current-conversation() -> Conversation {
        if (root.active_chat_id >= 0 && root.active_chat_id < root.chats.length) {
            return root.chats[root.active_chat_id];
        }
        return { id: "", name: "", last_message: "", last_message_time: "", unread_count: 0, messages: [] };
    }
    public pure function has-active-conversation() -> bool {
        return root.active_chat_id >= 0 && root.active_chat_id < root.chats.length;
    }
    callback switch_conversation(int);
    callback delete_conversation(int);
    callback send_message(string);
    callback create_new_conversation();
    callback confirm_new_conversation(/* username */ string);
    callback cancel_new_conversation();

    // New conversation dialog state
    in-out property <bool> show_new_conversation_dialog: false;
    in-out property <string> new_conversation_error: "";

    callback edit_message(/* msg_id */ string, /* new_text */ string);
    callback delete_message(/* msg_id */ string);
    callback start_edit(/* msg_id */ string, /* current_text */ string);
    callback cancel_edit();

    // Conversation settings
    in-out property <bool> show_conversation_settings: false;
    in-out property <[PeerData]> current_peers;
    callback open_conversation_settings();
    callback close_conversation_settings();
    callback rename_conversation(/* new_name */ string);
    callback add_member();

    // Typing indicator
    callback typing();
}
